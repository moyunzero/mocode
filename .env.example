# Base URL for the Hono API server (used by the CLI).
API_URL=http://localhost:3000

# PostgreSQL connection string for Prisma (used by the server).
# Use sslmode=verify-full explicitly (pg v9 will treat require/prefer as weaker libpq semantics).
DATABASE_URL=

# Sentry DSN for server observability (optional; omit to disable Sentry).
SENTRY_DSN=

# Trace sampling rate 0.0–1.0 (default 1.0 for local dev; use ~0.1 in production).
SENTRY_TRACES_SAMPLE_RATE=1.0

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Google AI Studio — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras — https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Clerk OAuth (phase 9) — https://clerk.com/keys
# Server: CLERK_SECRET_KEY + CLERK_PUBLISHABLE_KEY validate Bearer tokens on /sessions and /chat.
# CLI: CLERK_FRONTEND_API + CLERK_OAUTH_CLIENT_ID drive the browser /login PKCE flow.
CLERK_OAUTH_CLIENT_SECRECT=
CLERK_OAUTH_CLIENT_ID=
CLERK_FRONTEND_API=
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Register this Redirect URI in the Clerk Dashboard (must match API_URL):
#   ${API_URL}/auth/callback  →  default http://localhost:3000/auth/callback
# See doc/cli-tui-issue-oauth-redirect-uri.md for the CLI relay architecture.

# Polar credits billing (phase 10) — https://polar.sh
# Server: SDK uses these for checkout, portal, balance checks, and usage ingest.
# POLAR_SERVER: sandbox (default) or production.
# POLAR_CREDITS_METER_ID: meter that tracks prepaid credits (balance gate + decrement).
POLAR_ACCESS_TOKEN= 
POLAR_PRODUCT_ID=
POLAR_SERVER=sandbox
POLAR_CREDITS_METER_ID=